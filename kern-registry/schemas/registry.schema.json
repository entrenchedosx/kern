{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kern-lang.org/schemas/registry.schema.json",
  "title": "Kern Registry Index",
  "type": "object",
  "required": ["registryVersion", "packages"],
  "properties": {
    "registryVersion": { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string" },
    "packages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["latest", "metadata"],
        "properties": {
          "latest": { "type": "string" },
          "metadata": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
