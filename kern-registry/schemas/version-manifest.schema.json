{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kern-lang.org/schemas/version-manifest.schema.json",
  "title": "Kern Package Version Manifest",
  "type": "object",
  "required": ["name", "version", "main", "dependencies", "dist"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "main": { "type": "string" },
    "trusted": { "type": "boolean" },
    "dependencies": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "dist": {
      "type": "object",
      "required": ["tarball", "shasum"],
      "properties": {
        "tarball": { "type": "string" },
        "shasum": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
