{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kern-lang.org/schemas/package.schema.json",
  "title": "Kern Package Manifest",
  "type": "object",
  "required": ["name", "version", "main", "dependencies"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-._]{0,127}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "main": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
