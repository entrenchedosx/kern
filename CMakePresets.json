{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 19, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-vcpkg-static-release",
      "displayName": "Windows + vcpkg static Raylib (multi-config: build Release in IDE or CLI)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/tools/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "KERN_BUILD_GAME": "ON",
        "KERN_PREFER_STATIC_RAYLIB": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release-kern",
      "configurePreset": "windows-vcpkg-static-release",
      "configuration": "Release",
      "targets": ["kern", "kernc"]
    }
  ]
}
