// Smoke test for lib/kern/stdlib/* — run from repo root: kern tests/stdlib_ecosystem_smoke.kn
//
// Note: we import the exact modules used below so Kern's static global scan
// doesn't emit "Possible undefined variable" warnings.

import("lib/kern/testing.kn")
let m_b64 = import("lib/kern/stdlib/encoding/base64.kn")
let m_rot = import("lib/kern/stdlib/encoding/rot13.kn")
let m_graph = import("lib/kern/stdlib/graph/adjacency_list.kn")
let m_bfs = import("lib/kern/stdlib/graph/bfs_simple.kn")
let m_deque = import("lib/kern/stdlib/collections/deque.kn")

// Spot checks
let b64 = m_b64["base64_encode_bytes"](array(1, 2, 3, 4, 5))
let dec = m_b64["base64_decode_bytes"](b64)
assert_eq(len(dec), 5, "base64 roundtrip len")
assert_eq(dec[0], 1, "b64 b0")
assert_eq(dec[4], 5, "b64 b4")

let r = m_rot["rot13"]("hello")
assert_eq(r, "uryyb", "rot13")

let g = m_graph["graph_new"]()
m_graph["graph_add_edge"](g, "a", "b")
let dist = m_bfs["bfs_distances"](g, "a")
assert_eq(dist["b"], 1, "bfs")

let d = m_deque["deque_new"]()
m_deque["deque_push_back"](d, 1)
m_deque["deque_push_front"](d, 0)
assert_eq(m_deque["deque_pop_front"](d), 0, "deque")

print("stdlib_ecosystem_smoke: ok")
