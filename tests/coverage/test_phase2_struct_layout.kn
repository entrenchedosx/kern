struct Header {
  tag: u32,
  flags: u16,
  count: u16,
  data_ptr: ptr
}

assert_eq(sizeof_struct("Header"), 16)
assert_eq(offsetof_struct("Header", "tag"), 0)
assert_eq(offsetof_struct("Header", "flags"), 4)
assert_eq(offsetof_struct("Header", "count"), 6)
assert_eq(offsetof_struct("Header", "data_ptr"), 8)

print("OK: test_phase2_struct_layout")
