html = import("lib/kern/browserkit/html/parser.kn")
cssp = import("lib/kern/browserkit/css/parser.kn")
style = import("lib/kern/browserkit/css/style_engine.kn")
jsrt = import("lib/kern/browserkit/js_engine/runtime.kn")
q = import("lib/kern/browserkit/dom/query.kn")

src = "<html><body><div id='title' class='hero'>Loading...</div><p class='muted'>Body</p></body></html>"
css = "#title { color: white; background: #1f2a44; } .muted { color: #d5defa; }"

doc = html.parse(src)
rules = cssp.parse(css)
style.apply_styles(doc, rules)

ctx = jsrt.create_context(doc)
jsrt.run_script_lines(ctx, ["setText #title BrowserKit Demo"])

title = q.query_one(doc, "#title")
muted = q.query_one(doc, ".muted")
assert_eq(title != null, true)
assert_eq(muted != null, true)
assert_eq(title["text"], "BrowserKit Demo")
assert_eq(title["computed_style"]["color"], "white")
assert_eq(muted["computed_style"]["color"], "#d5defa")

print("test_browserkit_html_css_js_pipeline: pass")
