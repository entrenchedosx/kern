runtime_mod = import("lib/kern/runtime/modern/module.kn")
commands = import("lib/kern/runtime/modern/commands.kn")

let state = {}
state["attempts"] = 0
state["after"] = 0

@event("on_command", priority=100, retries=2, retry_delay_ms=0, stop_on_error=true)
def flaky_listener(ctx, payload) {
    state["attempts"] = int(state["attempts"]) + 1
    if (int(state["attempts"]) < 3) {
        throw Error("transient listener failure", "LISTENER-TRANSIENT")
    }
    return null
}

@event("on_command", priority=1)
def after_listener(ctx, payload) {
    state["after"] = int(state["after"]) + 1
    return null
}

@command("retry_cmd")
def retry_cmd(ctx, args) {
    return "ok"
}

let rt = runtime_mod.create_runtime({})
let named = {}
let res = commands.run_command(rt["commands"], rt["events"], rt["ctx"], "retry_cmd", named)
assert_eq(res["ok"], true)
assert_eq(res["value"], "ok")
assert_eq(state["attempts"], 3)
assert_eq(state["after"], 1)
print("ok")
