// append_file / appendFile — native append (std.v1.fs append_text maps here)
require("filesystem.read")
require("filesystem.write")
io = import("io")
let path = path_join(temp_dir(), "kern_append_smoke_" + str(random_int(99999999)) + ".txt")
assert_eq(write_file(path, "hel"), true)
assert_eq(append_file(path, "lo"), true)
assert_eq(read_file(path), "hello")
assert_eq(io.append_file(path, "!"), true)
assert_eq(io.appendFile(path, "?"), true)
assert_eq(read_file(path), "hello!?")
assert_eq(delete_file(path), true)
print("OK: test_append_file_builtin")
