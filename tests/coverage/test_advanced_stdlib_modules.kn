interop = import("interop")
concurrency = import("concurrency")
observability = import("observability")
security = import("security")
automation = import("automation")
binary = import("binary")
websec = import("websec")
netops = import("netops")
datatools = import("datatools")
runtime_controls = import("runtime_controls")

assert_eq(has(interop, "ffi_call"), true)
assert_eq(has(concurrency, "spawn"), true)
assert_eq(has(observability, "runtime_info"), true)
assert_eq(has(security, "sha256"), true)
assert_eq(has(automation, "exec_capture"), true)
assert_eq(has(binary, "read_le32"), true)
assert_eq(has(websec, "html_sanitize_strict"), true)
assert_eq(has(netops, "http_request"), true)
assert_eq(has(datatools, "json_parse"), true)
assert_eq(has(runtime_controls, "set_step_limit"), true)

print("OK: test_advanced_stdlib_modules")
