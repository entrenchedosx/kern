// if / else, for with range(), while, break
let n = 7
if (n % 2 == 0) {
    print("branch: even")
} else {
    print("branch: odd")
}

print("for i in range(1, 4):")
for i in range(1, 4) {
    print(i)
}

print("while + break:")
let j = 0
while (true) {
    j = j + 1
    print("j", j)
    if (j >= 2) {
        break
    }
}
