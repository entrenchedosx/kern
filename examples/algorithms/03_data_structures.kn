print("=== Binary Search Tree ===")

def createBST() {
    return {
        root: null,
        
        insert: def (value) {
            root = insertNode(root, value)
        },
        
        find: def (value) {
            return findNode(root, value)
        },
        
        inOrder: def () {
            let result = []
            inOrderTraversal(root, result)
            return result
        },
        
        min: def () {
            if (root == null) return null
            let node = root
            while (node.left != null) {
                node = node.left
            }
            return node.value
        },
        
        max: def () {
            if (root == null) return null
            let node = root
            while (node.right != null) {
                node = node.right
            }
            return node.value
        }
    }
}

def insertNode(node, value) {
    if (node == null) {
        return {value: value, left: null, right: null}
    }
    
    if (value < node.value) {
        node.left = insertNode(node.left, value)
    } else if (value > node.value) {
        node.right = insertNode(node.right, value)
    }
    
    return node
}

def findNode(node, value) {
    if (node == null) {
        return false
    }
    
    if (value == node.value) {
        return true
    }
    
    if (value < node.value) {
        return findNode(node.left, value)
    } else {
        return findNode(node.right, value)
    }
}

def inOrderTraversal(node, result) {
    if (node != null) {
        inOrderTraversal(node.left, result)
        result.append(node.value)
        inOrderTraversal(node.right, result)
    }
}

// Test BST
let bst = createBST()
bst.insert(50)
bst.insert(30)
bst.insert(70)
bst.insert(20)
bst.insert(40)
bst.insert(60)
bst.insert(80)

print("BST in-order: " + bst.inOrder())
print("Find 40: " + bst.find(40))
print("Find 100: " + bst.find(100))
print("Min: " + bst.min())
print("Max: " + bst.max())

