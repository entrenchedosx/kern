print("=== Stack (LIFO) ===")

// Stack implementation using array
let stack = {
    data: [],
    
    push: def (item) {
        data.append(item)
    },
    
    pop: def () {
        if (len(data) == 0) {
            return null
        }
        let item = data[len(data) - 1]
        data.pop()
        return item
    },
    
    peek: def () {
        if (len(data) == 0) {
            return null
        }
        return data[len(data) - 1]
    },
    
    isEmpty: def () {
        return len(data) == 0
    },
    
    size: def () {
        return len(data)
    }
}

// Test stack
stack.push(10)
stack.push(20)
stack.push(30)
print("Stack after pushes: " + stack.data)
print("Peek: " + stack.peek())
print("Pop: " + stack.pop())
print("Pop: " + stack.pop())
print("Size: " + stack.size())

print("")
print("=== Queue (FIFO) ===")

// Queue implementation
let queue = {
    data: [],
    head: 0,
    
    enqueue: def (item) {
        data.append(item)
    },
    
    dequeue: def () {
        if (head >= len(data)) {
            return null
        }
        let item = data[head]
        head = head + 1
        
        // Compact array when half empty
        if (head > len(data) / 2) {
            let newData = []
            for i in range(head, len(data)) {
                newData.append(data[i])
            }
            data = newData
            head = 0
        }
        
        return item
    },
    
    peek: def () {
        if (head >= len(data)) {
            return null
        }
        return data[head]
    },
    
    isEmpty: def () {
        return head >= len(data)
    },
    
    size: def () {
        return len(data) - head
    }
}

// Test queue
queue.enqueue("Alice")
queue.enqueue("Bob")
queue.enqueue("Carol")
print("Queue size: " + queue.size())
print("Dequeue: " + queue.dequeue())
print("Dequeue: " + queue.dequeue())
print("Peek: " + queue.peek())

print("")
print("=== Priority Queue ===")

def createPriorityQueue() {
    return {
        items: [],
        
        enqueue: def (item, priority) {
            let element = {item: item, priority: priority}
            let added = false
            
            for i in range(len(items)) {
                if (priority < items[i].priority) {
                    items.insert(i, element)
                    added = true
                    break
                }
            }
            
            if (!added) {
                items.append(element)
            }
        },
        
        dequeue: def () {
            if (len(items) == 0) {
                return null
            }
            return items.removeAt(0).item
        },
        
        peek: def () {
            if (len(items) == 0) {
                return null
            }
            return items[0].item
        },
        
        isEmpty: def () {
            return len(items) == 0
        }
    }
}

let pq = createPriorityQueue()
pq.enqueue("Low priority task", 5)
pq.enqueue("High priority task", 1)
pq.enqueue("Medium priority task", 3)
pq.enqueue("Urgent task", 0)

print("Priority queue processing:")
while (!pq.isEmpty()) {
    print("  " + pq.dequeue())
}

print("")
print("=== Linked List ===")

// Node constructor
def createNode(value, next) {
    return {value: value, next: next}
}

// Linked list
let linkedList = {
    head: null,
    size: 0,
    
    prepend: def (value) {
        head = createNode(value, head)
        size = size + 1
    },
    
    append: def (value) {
        if (head == null) {
            head = createNode(value, null)
        } else {
            let current = head
            while (current.next != null) {
                current = current.next
            }
            current.next = createNode(value, null)
        }
        size = size + 1
    },
    
    remove: def (value) {
        if (head == null) {
            return false
        }
        
        if (head.value == value) {
            head = head.next
            size = size - 1
            return true
        }
        
        let current = head
        while (current.next != null) {
            if (current.next.value == value) {
                current.next = current.next.next
                size = size - 1
                return true
            }
            current = current.next
        }
        
        return false
    },
    
    find: def (value) {
        let current = head
        while (current != null) {
            if (current.value == value) {
                return true
            }
            current = current.next
        }
        return false
    },
    
    toArray: def () {
        let result = []
        let current = head
        while (current != null) {
            result.append(current.value)
            current = current.next
        }
        return result
    }
}

// Test linked list
linkedList.append(10)
linkedList.append(20)
linkedList.prepend(5)
linkedList.append(30)
print("Linked list: " + linkedList.toArray())
print("Contains 20: " + linkedList.find(20))
linkedList.remove(20)
print("After removing 20: " + linkedList.toArray())

