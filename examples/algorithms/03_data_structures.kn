print("=== Graph (Adjacency List) ===")

let graph = {
    adjacencyList: {},
    
    addVertex: def (vertex) {
        if (adjacencyList[vertex] == null) {
            adjacencyList[vertex] = []
        }
    },
    
    addEdge: def (v1, v2) {
        if (adjacencyList[v1] == null) {
            addVertex(v1)
        }
        if (adjacencyList[v2] == null) {
            addVertex(v2)
        }
        adjacencyList[v1].append(v2)
        adjacencyList[v2].append(v1)  // Undirected
    },
    
    dfs: def (start) {
        let result = []
        let visited = {}
        dfsRecursive(start, visited, result)
        return result
    },
    
    bfs: def (start) {
        let result = []
        let visited = {}
        let queue = [start]
        visited[start] = true
        
        while (len(queue) > 0) {
            let vertex = queue.removeAt(0)
            result.append(vertex)
            
            for neighbor in adjacencyList[vertex] {
                if (visited[neighbor] == null) {
                    visited[neighbor] = true
                    queue.append(neighbor)
                }
            }
        }
        
        return result
    }
}

def dfsRecursive(vertex, visited, result) {
    visited[vertex] = true
    result.append(vertex)
    
    for neighbor in graph.adjacencyList[vertex] {
        if (visited[neighbor] == null) {
            dfsRecursive(neighbor, visited, result)
        }
    }
}

// Test graph
graph.addEdge("A", "B")
graph.addEdge("A", "C")
graph.addEdge("B", "D")
graph.addEdge("B", "E")
graph.addEdge("C", "F")
graph.addEdge("E", "F")

print("Graph adjacency list: " + graph.adjacencyList)
print("DFS from A: " + graph.dfs("A"))
print("BFS from A: " + graph.bfs("A"))

