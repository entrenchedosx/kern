let g3 = import("g3d")

g3.createWindow(1000, 700, "Kern g3d - Camera Modes")
g3.clear(8, 12, 20)
g3.setProjection("perspective")
g3.setFov(120)
g3.setCamera(6.0, 4.0, 6.0, 0.0, 0.5, 0.0)
g3.setCameraMode("orbit")
g3.showStats(true)

def update() {}

def draw() {
    g3.setColor(120, 120, 120)
    g3.drawGrid(30, 1.0)

    g3.setColor(255, 180, 90)
    g3.drawCube(0.0, 0.5, 0.0, 1.2)

    g3.setColor(90, 200, 255)
    g3.drawSphere(-2.2, 0.7, 1.5, 0.7)
}

g3.run(update, draw)











