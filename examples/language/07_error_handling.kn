// Pattern 2: Result type (using array)
def safeParseNumber(str) {
    try {
        // let num = parseFloat(str)
        // return [true, num]
        return [true, 42]  // Placeholder
    } catch (e) {
        return [false, e]
    }
}

let parseResult = safeParseNumber("123")
if (parseResult[0]) {
    print("Parsed: " + parseResult[1])
} else {
    print("Parse failed: " + parseResult[1])
}

let badResult = safeParseNumber("abc")
if (badResult[0]) {
    print("Parsed: " + badResult[1])
} else {
    print("Parse failed: " + badResult[1])
}

print("")
print("=== Resource Management Pattern ===")

def withFile(filename, mode, callback) {
    // let file = open(filename, mode)
    let file = {name: filename, mode: mode}  // Mock file
    
    try {
        let result = callback(file)
        return result
    } catch (e) {
        print("Error with file: " + e)
        throw e
    } finally {
        // file.close()
        print("File closed: " + file.name)
    }
}

// Usage:
// withFile("data.txt", "r", def (f) {
//     return f.read()
// })

print("Done!")
