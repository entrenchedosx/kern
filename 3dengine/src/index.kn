    if (!_ecs_require_structural_allowed(world, "world_register_material")) { return "" }
    if (!_ecs_require_write_allowed(world, "registry", "world_register_material")) { return "" }
    let hid = _ecs_registry_register_material(world, material)
    if (str(default(hid, "")) == "") { return "" }
    return hid
}
def _ecs_world_register_texture(world, texture) {
    if (!_ecs_require_structural_allowed(world, "world_register_texture")) { return "" }
    if (!_ecs_require_write_allowed(world, "registry", "world_register_texture")) { return "" }
    let hid = _ecs_registry_register_texture(world, texture)
    if (str(default(hid, "")) == "") { return "" }
    return hid
}
