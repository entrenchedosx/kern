def _ecs_world_register_mesh(world, mesh) {
    if (!_ecs_require_structural_allowed(world, "world_register_mesh")) { return "" }
    if (!_ecs_require_write_allowed(world, "registry", "world_register_mesh")) { return "" }
    let hid = _ecs_registry_register_mesh(world, mesh)
    if (str(default(hid, "")) == "") { return "" }
    return hid
}
