// oskit cpu/port.kn
// port I/O abstraction (safe emulation in hosted mode).

let _ports = {}

def write(port, value) {
    _ports[str(int(port))] = int(value) & 255
    return true
}

def read(port) {
    let k = str(int(port))
    if (!has(_ports, k)) { return 0 }
    return int(_ports[k]) & 255
}

def write16(port, value) {
    write(port, value & 255)
    write(port + 1, (value >> 8) & 255)
}

def read16(port) {
    return read(port) | (read(port + 1) << 8)
}
