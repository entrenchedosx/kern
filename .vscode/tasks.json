{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Kern: Run",
      "type": "shell",
      "command": "kern",
      "args": ["${file}"],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Kern: Run (build dir)",
      "type": "shell",
      "command": "${workspaceFolder}/build/Release/kern.exe",
      "args": ["${file}"],
      "windows": { "command": "${workspaceFolder}/build/Release/kern.exe" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Kern: Check",
      "type": "shell",
      "command": "kern",
      "args": ["--check", "${file}"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Kern: Lint",
      "type": "shell",
      "command": "kern",
      "args": ["--lint", "${file}"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Kern: Format",
      "type": "shell",
      "command": "kern",
      "args": ["--fmt", "${file}"],
      "group": "none",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "Kern: AST",
      "type": "shell",
      "command": "kern",
      "args": ["--ast", "${file}"],
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Kern: Bytecode",
      "type": "shell",
      "command": "kern",
      "args": ["--bytecode", "${file}"],
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Kern: Stable suite",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tests/run_stable.ps1"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\tests\\run_stable.ps1"
        ]
      },
      "linux": {
        "command": "pwsh",
        "args": ["-NoProfile", "-File", "${workspaceFolder}/tests/run_stable.ps1"]
      },
      "osx": {
        "command": "pwsh",
        "args": ["-NoProfile", "-File", "${workspaceFolder}/tests/run_stable.ps1"]
      },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Kern: Stable (quick)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tests/run_stable.ps1",
        "-Quick"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\tests\\run_stable.ps1",
          "-Quick"
        ]
      },
      "linux": {
        "command": "pwsh",
        "args": ["-NoProfile", "-File", "${workspaceFolder}/tests/run_stable.ps1", "-Quick"]
      },
      "osx": {
        "command": "pwsh",
        "args": ["-NoProfile", "-File", "${workspaceFolder}/tests/run_stable.ps1", "-Quick"]
      },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Kern: Docs build + postprocess",
      "type": "shell",
      "command": "mkdocs build --strict && python tools/postprocess_site.py",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
